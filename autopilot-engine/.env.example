# -----------------------------------------------------------------------------
# Growth Autopilot Engine Configuration Template
# Rename this file to '.env' and fill in your keys.
# -----------------------------------------------------------------------------

# Gemini API Key (Required for writing pitches)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenPageRank API Key (Optional: for domain authority filtering. If left blank, scripts use heuristic estimation)
OPEN_PAGE_RANK_KEY=

# Meta Graph API (Optional: for automated posting to Facebook Page)
META_ACCESS_TOKEN=
FB_PAGE_ID=

# LinkedIn API (Optional: for automated posting to LinkedIn profile/company page)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
